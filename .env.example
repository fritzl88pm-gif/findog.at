# Supabase Auth in the browser. These values are safe to expose because they use
# the public anon key, not the service role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side Supabase Auth validation and chat persistence. Never expose the
# service role key to browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only DeepSeek key for the fixed DeepSeek Flash/Pro models. Do not
# expose this to browser code. GLOBAL_DEEPSEEK_API_KEY is an optional fallback.
DEEPSEEK_API_KEY=
# GLOBAL_DEEPSEEK_API_KEY=

# Server-only Z.AI GLM Coding Plan key for the centrally managed GLM models.
# Store the value as a protected Coolify runtime environment variable. Never
# expose it through a NEXT_PUBLIC_ variable or commit it to this repository.
ZAI_API_KEY=

# Server-only token for BFG/WeKnora MCP. Do not expose this to browser code.
BFG_MCP_BEARER_TOKEN=

# Server-only OpenRouter key for fixed Gemini 3.5 Flash PDF/OCR context extraction.
# The browser never receives this key.
OPENROUTER_API_KEY=
