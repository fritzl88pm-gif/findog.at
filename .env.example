# Supabase Auth in the browser. These values are safe to expose because they use
# the public anon key, not the service role key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side Supabase Auth validation and chat persistence. Never expose the
# service role key to browser code.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only DeepSeek key for BFG Suche PRO. Do not expose this to browser
# code. GLOBAL_DEEPSEEK_API_KEY is an optional fallback.
DEEPSEEK_API_KEY=
# GLOBAL_DEEPSEEK_API_KEY=

# Fred via the native Findog chat UI and WeKnora's secure embed API. All values
# stay server-side; the browser receives neither token nor session signature.
# The publish token must start with em_ and is not the account API key (sk-...).
# Configure the same exchange origin in the channel's allowed_origins list.
WEKNORA_FRED_CHANNEL_ID=
WEKNORA_FRED_PUBLISH_TOKEN=
WEKNORA_FRED_EXCHANGE_ORIGIN=https://findog.at
# Shared HMAC secret configured for Fred's WeKnora message_sent/message_received
# webhook. Use at least 32 random characters and keep it server-side.
WEKNORA_FRED_WEBHOOK_SECRET=

# Server-only bearer token for the read-only WeKnora knowledge dashboard MCP.
# The endpoint override is optional and should remain HTTPS outside tests.
WEKNORA_READONLY_MCP_BEARER_TOKEN=
# WEKNORA_READONLY_MCP_URL=https://taxdog.cloud/mcp/bfg-query

# Server-only OpenRouter key for Scanning and image-assisted form extraction.
# The browser never receives this key.
OPENROUTER_API_KEY=

# Server-only MinerU API token for attachment preprocessing.
# The browser never receives this key.
MINERU_API_TOKEN=
